{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "paths": {
      "@crm/shared": ["../../packages/shared/src/index.ts"],
      "@crm/core":   ["../../packages/core/src/index.ts"],
      "@crm/core/*": ["../../packages/core/src/*"]
    }
  },
  "include": ["src"],
  "exclude": ["dist", "node_modules"]
}
