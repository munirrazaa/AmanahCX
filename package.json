{
  "name": "crm-platform",
  "version": "1.0.0",
  "private": true,
  "packageManager": "npm@11.12.1",
  "workspaces": [
    "packages/*",
    "modules/*"
  ],
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "db:migrate": "turbo run db:migrate --filter=@crm/api",
    "db:seed": "turbo run db:seed --filter=@crm/api",
    "docker:dev": "docker-compose -f infra/docker/docker-compose.dev.yml up",
    "docker:prod": "docker-compose -f infra/docker/docker-compose.prod.yml up -d"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.0"
  }
}
