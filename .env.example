# ================================================================
# CRM Platform — Environment Variables
# Copy to .env and fill in values before running
# ================================================================

# ── Server ──────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# Your platform's root domain (tenants become slug.PLATFORM_DOMAIN)
PLATFORM_DOMAIN=yourcrm.com
APP_URL=https://yourcrm.com           # Used in CSAT survey email links
API_BASE_URL=https://api.yourcrm.com
CORS_ORIGINS=https://yourcrm.com,https://*.yourcrm.com

# ── Database ─────────────────────────────────────────────────────
DATABASE_URL=postgresql://crm:changeme@localhost:5432/crm_platform
# For production, use connection pooling (PgBouncer / Supabase)
# DATABASE_URL=postgresql://crm:changeme@pgbouncer:5432/crm_platform

# ── Redis ────────────────────────────────────────────────────────
REDIS_URL=redis://:changeme@localhost:6379

# ── Auth ─────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-256-bit-random-secret

# ── Stripe (global card payments: USD, EUR, GBP) ─────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Price IDs from Stripe dashboard:
STRIPE_PRICE_STARTER_MONTHLY=price_...
STRIPE_PRICE_STARTER_ANNUAL=price_...
STRIPE_PRICE_PROFESSIONAL_MONTHLY=price_...
STRIPE_PRICE_PROFESSIONAL_ANNUAL=price_...

# ── Wise (international transfers — USD, GBP, EUR, PKR) ──────────
WISE_API_KEY=your-wise-api-key
WISE_PROFILE_ID=your-wise-business-profile-id
WISE_WEBHOOK_SECRET=your-wise-webhook-secret
WISE_SANDBOX=false
# Your Wise receiving account details (shown to customers for bank transfer):
WISE_USD_ACCOUNT_NUMBER=
WISE_USD_ROUTING=
WISE_GBP_IBAN=
WISE_PKR_IBAN=PK36MEZN0001100123456789

# ── JazzCash (Pakistan — PKR mobile wallet) ───────────────────────
# Apply at: https://sandbox.jazzcash.com.pk/
JAZZCASH_MERCHANT_ID=your-merchant-id
JAZZCASH_PASSWORD=your-password
JAZZCASH_INTEGRITY_KEY=your-integrity-salt
JAZZCASH_SANDBOX=false

# ── Easypaisa (Pakistan — PKR mobile wallet, Telenor) ────────────
# Apply at: https://easypaisa.com.pk/merchant-portal/
EASYPAISA_STORE_ID=your-store-id
EASYPAISA_HASH_KEY=your-hash-key
EASYPAISA_USERNAME=your-username
EASYPAISA_PASSWORD=your-password
EASYPAISA_SANDBOX=false

# ── Raast (Pakistan — SBP instant interbank payment via 1LINK) ────
# Apply via 1LINK PSP: https://1link.net.pk or Finja/NayaPay
# Supports: HBL, UBL, MCB, Meezan, Bank Alfalah, all SBP member banks
RAAST_CLIENT_ID=your-client-id
RAAST_CLIENT_SECRET=your-client-secret
RAAST_MERCHANT_IBAN=PK36MEZN0001100123456789   # Your Raast IBAN
RAAST_MERCHANT_ALIAS=+923001234567              # Your Raast ID (phone/CNIC alias)
RAAST_ACCOUNT_TITLE=Your Company Name
RAAST_SANDBOX=false

# ── Pakistan Tax (for invoice GST) ───────────────────────────────
# Register with FBR: https://iris.fbr.gov.pk/
COMPANY_NTN=1234567-8            # National Tax Number
COMPANY_STRN=12-34-5678-001-23   # Sales Tax Registration Number (for GST on SaaS)

# ── Platform SMS Gateway (optional) ─────────────────────────────────
# AmanahCX's own shared SMS account, opt-in per tenant via Super Admin.
PLATFORM_SMS_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PLATFORM_SMS_AUTH_TOKEN=your-auth-token
PLATFORM_SMS_FROM_NUMBER=+12025551234

# ── Voice Providers ───────────────────────────────────────────────
# Twilio (default)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_DEFAULT_FROM_NUMBER=+12025551234

# Vonage / Nexmo (alternative)
VONAGE_API_KEY=your-api-key
VONAGE_API_SECRET=your-api-secret
VONAGE_DEFAULT_FROM_NUMBER=+12025551234

# ── Email ────────────────────────────────────────────────────────
SENDGRID_API_KEY=SG.xxxxx
FROM_EMAIL=noreply@yourcrm.com
FROM_NAME=CRM Platform

# ── Frontend (Vite build-time) ────────────────────────────────────
VITE_API_URL=https://api.yourcrm.com
VITE_WS_URL=wss://api.yourcrm.com

# ── Docker Compose (on-prem self-hosted deployment) ───────────────
# These are used by docker-compose.yml when running locally or on-prem.
# For Docker Compose, DATABASE_URL and REDIS_URL are auto-constructed.
POSTGRES_USER=crm
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=crm_platform
POSTGRES_PORT=5432

REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_PORT=6379

# Exposed ports for Docker Compose
FRONTEND_PORT=80
API_PORT=3000

# ── File Storage (S3-compatible) ─────────────────────────────────
# Option A — AWS S3: leave S3_ENDPOINT blank, set region/bucket/keys
# Option B — MinIO (on-prem): S3_ENDPOINT=http://minio:9000
#   → Uncomment the minio service block in docker-compose.yml
S3_ENDPOINT=
S3_REGION=us-east-1
S3_BUCKET=crm-uploads
S3_ACCESS_KEY=
S3_SECRET_KEY=
